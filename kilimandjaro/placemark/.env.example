# Public URL of the app (used for OIDC redirect URI)
APP_BASE_URL=https://placemark.example.com

# Auth mode: "oidc" (default) or "forward_auth"
# Use "forward_auth" with a reverse proxy (e.g. Caddy + Authentik outpost).
# In forward_auth mode the OIDC vars below are ignored.
AUTH_MODE=forward_auth

# Random secret for signing JWT session cookies
# Generate with: openssl rand -hex 32
JWT_SECRET=

# MapTiler API key for map tiles (get one at https://cloud.maptiler.com)
# Restrict it to your domain in the MapTiler dashboard
MAPTILER_API_KEY=

# Authentik OIDC — create an OAuth2/OIDC provider in Authentik
# Issuer URL: Settings > System > Authentik instance URL + /application/o/<slug>/
OIDC_ISSUER_URL=https://auth.example.com/application/o/placemark/
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
